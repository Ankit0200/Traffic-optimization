 Load the image\n","    image = cv2.imread(image_path)\n","    image = cv2.cvtColor(image, cv2.COLOR_BGR2RGB) # Convert to RGB for Matplotlib\n","\n","    # 3. Parse the XML file\n","    tree = ET.parse(xml_path)\n","    root = tree.getroot()\n","\n","    # 4. Loop through every object in the XML\n","    for obj in root.findall('object'):\n","        class_name = obj.find('name').text\n","        bndbox = obj.find('bndbox')\n","\n","        # Get coordinates\n","        xmin = int(bndbox.find('xmin').text)\n","        ymin = int(bndbox.find('ymin').text)\n","        xmax = int(bndbox.find('xmax').text)\n","        ymax = int(bndbox.find('ymax').text)\n","\n","        # Draw the box on the image\n","        # (Color is Red: (255, 0, 0), Thickness is 2)\n","        cv2.rectangle(image, (xmin, ymin), (xmax, ymax), (255, 0, 0), 2)\n","\n","        # Put the label text above the box\n","        cv2.putText(image, class_name, (xmin, ymin - 10),\n","                    cv2.FONT_HERSHEY_SIMPLEX, 0.9, (255, 0, 0), 2)\n","\n","    # 5. Display the final result\n","    plt.figure(figsize=(10, 10))\n","    plt.imshow(image)\n","    plt.axis('off')\n","    plt.show()\n","\n","# --- USAGE ---\n","# Replace these paths with the actual paths from your dataset\n","img_file = f\"/content/roundabout_dataset/original/original/imgs/{orignal}\"\n","xml_file = f\"/content/roundabout_dataset/original/original/annotations/{one_file}\"\n","\n","visualize_xml(img_file, xml_file)"],"metadata":{"colab":{"base_uri":"https://localhost:8080/","height":472},"id":"DhMp035KOIEs","executionInfo":{"status":"ok","timestamp":1770490259379,"user_tz":360,"elapsed":1562,"user":{"displayName":"Ankit Devkota","userId":"08328117834516246160"}},"outputId":"0838d6d4-4664-4267-9e21-a0dbd50bf8c3"},"execution_count":10,"outputs":[{"output_type":"display_data","data":{"text/plain":["<Figure size 1000x1000 with 1 Axes>"],"image/png":"\n"},"metadata":{}}]},{"cell_type":"code","source":[],"metadata":{"id":"hHH7PoAqO2FO