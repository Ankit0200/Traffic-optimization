the XML, extracting image dimensions and bounding boxes, normalizing coordinates, and formatting them for YOLO. Then, I will iterate through all XML annotation files in the specified directory, apply this conversion function, and save the results in a new directory structure.\n","\n"]},{"cell_type":"code","metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"e7d8e8ac","executionInfo":{"status":"ok","timestamp":1770490285538,"user_tz":360,"elapsed":8261,"user":{"displayName":"Ankit Devkota","userId":"08328117834516246160"}},"outputId":"161afb49-eb53-4132-d015-363f3a278a88"},"source":["import xml.etree.ElementTree as ET\n","import os\n","import cv2\n","\n","# 1. Define a function convert_pascal_to_yolo\n","def convert_pascal_to_yolo(xml_path, image_path, class_mapping):\n","    # 2a. Use xml.etree.ElementTree to parse the XML file\n","    tree = ET.parse(xml_path)\n","    root = tree.getroot()\n","\n","    # 2b. Extract the image width and height from the XML's <size> tags\n","    # Or by loading the image using cv2.imread()\n","    size = root.find('size')\n","    if size is not None:\n","        img_width = int(size.find('width').text)\n","        img_height = int(size.find('height').text)\n","    else:\n","        # Fallback to loading the image if size info is not in XML\n","        img = cv2.imread(image_path)\n","        if img is None:\n","            print(f\"Warning: Could not read image {image_path}. Skipping.\")\n","            return []\n","        img_height, img_width, _ = img.shape\n","\n","    # 2c. Initialize an empty list to store YOLO annotation lines\n","    yolo_annotations = []\n","\n","    # 2d. Iterate through each <object> tag in the XML file\n","    for obj in root.findall('object'):\n","        # 2e. For each object, extract the class name and its bounding box coordinates\n","        class_name = obj.find('name').text\n","        bndbox = obj.find('bndbox')\n","        xmin = float(bndbox.find('xmin').text)\n","        ymin = float(bndbox.find('ymin').text)\n","        xmax = float(bndbox.find('xmax').text)\n","        ymax = float(bndbox.find('ymax').text)\n","\n","        # 2f. Convert PASCAL VOC to YOLO format and normalize\n","        x_center = (xmin + xmax) / 2 / img_width\n","        y_center = (ymin + ymax) / 2 / img_height\n","        width = (xmax - xmin) / img_width\n","        height = (ymax - ymin) / img_height\n","\n","        # 2g. Get the class ID\n","        class_id = class_mapping.get(class_name)\n","        if class_id is None:\n","            print(f\"Warning: Class '{class_name}' not found in mapping. Skipping object.\")\n","            continue\n","\n","        # 2h. Format the converted values and append to list\n","        yolo_annotations.append(f'{class_id} {x_center:.6f} {y_center:.6f} {width:.6f} {height:.6f}')\n","\n","    # 2i. Return the list of YOLO annotation lines\n","    return yolo_annotations\n","\n","# 3. Create a new directory, yolo_labels, to store the converted YOLO .txt files\n","yolo_labels_dir = os.path.join(destination_path, 'yolo_labels')\n","os.makedirs(yolo_labels_dir, exist_ok=True)\n","\n","# 4. Set up the VOC_ROOT directory\n","VOC_ROOT = os.path.join(destination_path, 'original', 'original')\n","annotations_dir = os.path.join(VOC_ROOT, 'annotations')\n","images_dir = os.path.join(VOC_ROOT, 'imgs')\n","\n","# 5. Create a dictionary to map class names to integers\n","class_map = {'vehicle': 0}\n","\n","processed_count = 0\n","# 6. Loop through all XML files in the VOC_ROOT/annotations directory\n","for xml_filename in os.listdir(annotations_dir):\n","    if xml_filename.endswith('.xml'):\n","        xml_filepath = os.path.join(annotations_dir, xml_filename)\n","\n","        # 7a. Construct the corresponding image file path\n","        # Assuming XML filename like '00031_frame000038_original.xml'\n","        # corresponds to '00031_frame000038_original.jpg'\n","        image_filename = xml_filename.replace('.xml', '.jpg')\n","        image_filepath = os.path.join(images_dir, image_filename)\n","\n","        # 7b. Call the convert_pascal_to_yolo function\n","        yolo_lines = convert_pascal_to_yolo(xml_filepath, image_filepath, class_map)\n","\n","        # 7c. Construct the output YOLO label file path\n","        yolo_label_filename = xml_filename.replace('.xml', '.txt')\n","        yolo_label_filepath = os.path.join(yolo_labels_dir, yolo_label_filename)\n","\n","        # 7d. Write the returned YOLO annotation lines to the output .txt file\n","        if yolo_lines:\n","            with open(yolo_label_filepath, 'w') as f:\n","                for line in yolo_lines:\n","                    f.write(line + '\\n')\n","            processed_count += 1\n","\n","# 8. Print a confirmation message once all files are converted.\n","print(f\"Successfully converted {processed_count} XML files to YOLO format in {yolo_labels_dir}\")"],"execution_count":12,"outputs":[{"output_type":"stream","name":"stdout","text":["\u001b[1;30;43mStreaming output truncated to the last 5000 lines.\u001b[0m\n","Warning: Class 'cycle' not found in mapping. Skipping object.\n","Warning: Class 'cycle' not found in mapping. Skipping object.\n","Warning: Class 'cycle' not found in mapping. Skipping object.\n","Warning: Class 'bus' not found in mapping. Skipping object.\n","Warning: Class 'truck' not found in mapping. Skipping object.\n","Warning: Class 'truck' not found in mapping. Skipping object.\n","Warning: Class 'cycle' not found in mapping. Skipping object.\n","Warning: Class 'cycle' not found in mapping. Skipping object.\n","Warning: Class 'bus' not found in mapping. Skipping object.\n","Warning: Class 'truck' not found in mapping. Skipping object.\n","Warning: Class 'truck' not found in mapping. Skipping object.\n","Warning: Class 'cycle' not found in mapping. Skipping object.\n","Warning: Class 'cycle' not found in mapping. Skipping object.\n","Warning: Class 'cycle' not found in mapping. Skipping object.\n","Warning: Class 'cy