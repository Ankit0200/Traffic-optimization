<edges>
    <!-- Inbound edges (toward intersection) — 30 km/h = 8.33 m/s -->
    <edge id="N_to_C" from="N" to="C" numLanes="2" speed="8.33"/>
    <edge id="S_to_C" from="S" to="C" numLanes="2" speed="8.33"/>
